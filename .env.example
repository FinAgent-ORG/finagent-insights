APP_NAME=finagent-insights-service # [CONFIGMAP]
APP_ENV=development # [CONFIGMAP]
APP_HOST=0.0.0.0 # [CONFIGMAP]
APP_PORT=8003 # [CONFIGMAP]
JWT_SECRET_KEY=replace-with-a-long-random-value # [SECRET]
JWT_ALGORITHM=HS256 # [CONFIGMAP]
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173 # [CONFIGMAP]
RATE_LIMIT_REQUESTS=120 # [CONFIGMAP]
RATE_LIMIT_WINDOW_SECONDS=60 # [CONFIGMAP]
EXPENSE_SERVICE_BASE_URL=http://localhost:8002 # [CONFIGMAP]
OLLAMA_BASE_URL=http://localhost:11434 # [CONFIGMAP]
OLLAMA_MODEL=llama3.1 # [CONFIGMAP]
OLLAMA_TEMPERATURE=0 # [CONFIGMAP]
